      <title>javaString类</title>
      <link href="/2021/12/25/java%E5%AD%A6%E4%B9%A0/javase/"/>
      <url>/2021/12/25/java%E5%AD%A6%E4%B9%A0/javase/</url>
      
        <content type="html"><![CDATA[<img src="https://gitee.com/jyxzwd/blogpic/raw/master/img/1627009410695.png" style="zoom:67%;" /><figure class="highlight java"><table><tr><td class="gutter"><pre><span class="line">1</span><br><span class="line">2</span><br><span class="line">3</span><br><span class="line">4</span><br><span class="line">5</span><br><span class="line">6</span><br><span class="line">7</span><br><span class="line">8</span><br><span class="line">9</span><br><span class="line">10</span><br><span class="line">11</span><br><span class="line">12</span><br><span class="line">13</span><br><span class="line">14</span><br><span class="line">15</span><br><span class="line">16</span><br><span class="line">17</span><br><span class="line">18</span><br><span class="line">19</span><br><span class="line">20</span><br><span class="line">21</span><br><span class="line">22</span><br><span class="line">23</span><br><span class="line">24</span><br><span class="line">25</span><br><span class="line">26</span><br><span class="line">27</span><br><span class="line">28</span><br><span class="line">29</span><br><span class="line">30</span><br><span class="line">31</span><br><span class="line">32</span><br><span class="line">33</span><br><span class="line">34</span><br><span class="line">35</span><br><span class="line">36</span><br><span class="line">37</span><br><span class="line">38</span><br><span class="line">39</span><br><span class="line">40</span><br><span class="line">41</span><br><span class="line">42</span><br><span class="line">43</span><br><span class="line">44</span><br><span class="line">45</span><br><span class="line">46</span><br><span class="line">47</span><br><span class="line">48</span><br><span class="line">49</span><br><span class="line">50</span><br><span class="line">51</span><br><span class="line">52</span><br><span class="line">53</span><br></pre></td><td class="code"><pre><span class="line"><span class="keyword">package</span> String_class;</span><br><span class="line"><span class="comment">/*</span></span><br><span class="line"><span class="comment">String 类被创建后其内容不可被更改。</span></span><br><span class="line"><span class="comment"> */</span></span><br><span class="line"><span class="keyword">public</span> <span class="class"><span class="keyword">class</span> <span class="title">String_app</span> </span>&#123;</span><br><span class="line">    <span class="function"><span class="keyword">public</span> <span class="keyword">static</span> <span class="keyword">void</span> <span class="title">main</span><span class="params">(String[] args)</span> </span>&#123;</span><br><span class="line">        String name = <span class="string">&quot;测试&quot;</span>;</span><br><span class="line">        <span class="comment">//&quot;测试&quot;存在于堆内存中的字符串常量池，name指向“测试”</span></span><br><span class="line">        name += <span class="string">&quot;成功&quot;</span>;</span><br><span class="line">        <span class="comment">//“成功”也被存于字符串常量池中；</span></span><br><span class="line">        <span class="comment">//经运算后的“测试成功”被重新存在于堆内存中，name指向“测试成功”，</span></span><br><span class="line">        <span class="comment">//每次String类每次修改都是产生并指向新的字符串对象，而原来的字符串对象还在常量池中</span></span><br><span class="line">        <span class="keyword">byte</span> [] b = &#123;<span class="number">97</span>,<span class="number">98</span>,<span class="number">99</span>&#125;;</span><br><span class="line">        String s2 = <span class="keyword">new</span> String(b);</span><br><span class="line">        String s1 = <span class="string">&quot;abc&quot;</span>;</span><br><span class="line">        String s3 = <span class="string">&quot;abc&quot;</span>;</span><br><span class="line">        <span class="comment">//以“”方式给出的字符串对象，在字符串 常量池中存储，且相同内容的只存储一份</span></span><br><span class="line">        <span class="comment">//而new出来的String储存在堆内存中</span></span><br><span class="line">        System.out.println(s1==s3);</span><br><span class="line">        System.out.println(s1.equals(s2));</span><br><span class="line">        <span class="comment">//==比较的是地址，而equals比较的是内容。</span></span><br><span class="line">        String s4 = <span class="keyword">new</span> String(<span class="string">&quot;def&quot;</span>);</span><br><span class="line">        <span class="comment">//22行常见了两个对象，“def”双引号里的在常量池中中，new出来的对象在堆内存中</span></span><br><span class="line">        String s5 = <span class="string">&quot;def&quot;</span>;</span><br><span class="line">        <span class="comment">//24行创建了0个对象，因为“def”已经在22行创建在常量池中，</span></span><br><span class="line">        System.out.println(s5==s4);</span><br><span class="line">        <span class="comment">//s5指向常量池中的“def”，而s4指向堆</span></span><br><span class="line">        String s6 = <span class="string">&quot;mno&quot;</span>;</span><br><span class="line">        String s7 = <span class="string">&quot;m&quot;</span>+<span class="string">&#x27;n&#x27;</span>+<span class="string">&#x27;o&#x27;</span>;</span><br><span class="line">        System.out.println(s6==s7);</span><br><span class="line">        <span class="comment">//编译时s7会转换为“nmo”</span></span><br><span class="line">        String s8 = <span class="string">&quot;poi&quot;</span>;</span><br><span class="line">        String s9 = <span class="string">&quot;po&quot;</span>;</span><br><span class="line">        String s10 = <span class="string">&quot;i&quot;</span>+s9;</span><br><span class="line">        System.out.println(s10==s8);</span><br><span class="line">        String  j = <span class="string">&quot;langyu&quot;</span>;</span><br><span class="line">        System.out.println(j.length());</span><br><span class="line">        <span class="comment">//转换为字符数组</span></span><br><span class="line">        System.out.println(j.charAt(<span class="number">0</span>));</span><br><span class="line">        <span class="keyword">char</span> [] chars = j.toCharArray();</span><br><span class="line">        <span class="comment">//截取内容</span></span><br><span class="line">        System.out.println(j.substring(<span class="number">0</span>, <span class="number">4</span>));</span><br><span class="line">        System.out.println(j.substring(<span class="number">4</span>));</span><br><span class="line">        String y= <span class="string">&quot;,,R至死,,,不渝 ， love朗郁 ,居云岫，无欢抑&quot;</span>;</span><br><span class="line">        System.out.println(y.replace(<span class="string">&quot;至死不渝&quot;</span>, <span class="string">&quot;居云岫&quot;</span>));</span><br><span class="line">        System.out.println(y.contains(<span class="string">&quot;朗郁&quot;</span>));</span><br><span class="line">        System.out.println(y.startsWith(<span class="string">&quot;langyu&quot;</span>));</span><br><span class="line">        String[] x = y.split((<span class="string">&quot;,&quot;</span>));</span><br><span class="line">        <span class="keyword">for</span> (<span class="keyword">int</span> i = <span class="number">0</span>; i &lt; x.length; i++) &#123;</span><br><span class="line">            System.out.println(x[i]);</span><br><span class="line">        &#125;</span><br><span class="line">    &#125;</span><br><span class="line">&#125;</span><br></pre></td></tr></table></figure>]]></content>
      
      
